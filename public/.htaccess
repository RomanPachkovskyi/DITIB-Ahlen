# ══════════════════════════════════════════════════════════════
# DITIB AHLEN — KULTURZENTRUM
# .htaccess for Apache hosting
# ══════════════════════════════════════════════════════════════

Options -Indexes
Options -MultiViews

# ── Engine ───────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS + non-www in a single hop
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\. [NC]
  RewriteRule ^ https://ditib-ahlen-projekte.de%{REQUEST_URI} [R=301,L]

  # Normalize /tr → /tr/ (trailing slash)
  RewriteRule ^tr$ /tr/ [R=301,L]

  # SPA fallback — only for extension-less app routes
  # Static file paths (js, css, images, etc.) fall through to Apache's 404
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.(js|css|png|jpg|jpeg|gif|svg|webp|avif|woff2?|ttf|ico|pdf|mp4|txt|xml|json|php|map)$ [NC]
  RewriteRule ^ /index.html [L]
</IfModule>

# ── MIME Types ────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType text/plain                  .txt
  AddType application/xml             .xml
  AddType application/javascript      .js
  AddType text/css                    .css
  AddType image/svg+xml               .svg
  AddType image/webp                  .webp
  AddType font/woff2                  .woff2
  AddType application/pdf             .pdf
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Cache Headers ────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Static assets — 1 year (Vite fingerprints filenames)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"

  # PDF and video — 30 days
  ExpiresByType application/pdf           "access plus 30 days"
  ExpiresByType video/mp4                 "access plus 30 days"

  # SEO files — 1 day
  ExpiresByType text/plain                "access plus 1 day"
  ExpiresByType application/xml           "access plus 1 day"

  # HTML — no cache (always fresh)
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set X-XSS-Protection          "1; mode=block"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Permissions-Policy        "camera=(), microphone=(), geolocation=()"

  # HSTS — 1 year, includes portal subdomain (mitglied.*).
  # No preload: preload-list submission is a long-term irreversible commitment.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # CSP DRAFT — не активований. Активувати після тестування consent-flow.
  # Причина: GA/Clarity/Maps/lottie потребують unsafe-inline та unsafe-eval;
  # блокуючий CSP без live-тесту може зламати analytics та карту.
  #
  # Header always set Content-Security-Policy "\
  #   default-src 'self'; \
  #   script-src 'self' 'unsafe-inline' 'unsafe-eval' \
  #     https://www.googletagmanager.com \
  #     https://www.google-analytics.com \
  #     https://www.clarity.ms \
  #     https://maps.googleapis.com; \
  #   style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; \
  #   font-src 'self' https://fonts.gstatic.com; \
  #   img-src 'self' data: https: blob:; \
  #   frame-src https://www.google.com; \
  #   connect-src 'self' \
  #     https://www.google-analytics.com \
  #     https://www.clarity.ms \
  #     https://maps.googleapis.com; \
  #   media-src 'self'; \
  #   object-src 'none'; \
  #   base-uri 'self'"

  <FilesMatch "\.(?:css|js|mjs|jpg|jpeg|png|gif|svg|webp|avif|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(?:mp4)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "no-cache, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Block aggressive bots ─────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|DotBot|MJ12bot|BLEXBot) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ── Protect sensitive files ───────────────────────────────────
<FilesMatch "(^\.env|\.git|\.htaccess)">
  Order allow,deny
  Deny from all
</FilesMatch>
