# ══════════════════════════════════════════════════════════════
# DITIB AHLEN — KULTURZENTRUM
# .htaccess for Apache hosting
# ══════════════════════════════════════════════════════════════

Options -Indexes
Options -MultiViews

# ── Engine ───────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Force non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # SPA fallback — serve index.html for all non-file routes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ /index.html [L]
</IfModule>

# ── MIME Types ────────────────────────────────────────────────
<IfModule mod_mime.c>
  AddType text/plain                  .txt
  AddType application/xml             .xml
  AddType image/svg+xml               .svg
  AddType image/webp                  .webp
  AddType font/woff2                  .woff2
  AddType application/pdf             .pdf
</IfModule>

# ── Gzip Compression ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Cache Headers ────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Static assets — 1 year (Vite fingerprints filenames)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"

  # PDF — 30 days
  ExpiresByType application/pdf           "access plus 30 days"

  # SEO files — 1 day
  ExpiresByType text/plain                "access plus 1 day"
  ExpiresByType application/xml           "access plus 1 day"

  # HTML — no cache (always fresh)
  ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

# ── PDF: force download ───────────────────────────────────────
<FilesMatch "\.pdf$">
  Header set Content-Disposition "attachment"
</FilesMatch>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set X-XSS-Protection          "1; mode=block"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Permissions-Policy        "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Block aggressive bots ─────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_USER_AGENT} (AhrefsBot|SemrushBot|DotBot|MJ12bot|BLEXBot) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# ── Protect sensitive files ───────────────────────────────────
<FilesMatch "(^\.env|\.git|\.htaccess)">
  Order allow,deny
  Deny from all
</FilesMatch>
